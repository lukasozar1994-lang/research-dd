    {"relative_path": ".vscode/mcp.json", "source": "generated", "overwrite_policy": "overwrite", "description": "MCP server configuration"},
    {"relative_path": ".vscode/settings.json", "source": "template", "overwrite_policy": "skip", "description": "VS Code settings"},
    {"relative_path": "package.json", "source": "generated", "overwrite_policy": "skip", "description": "NPM package manifest"},
    {"relative_path": ".env.example", "source": "generated", "overwrite_policy": "overwrite", "description": "Environment variable example"}
  ],
  "mcp_servers": [
    {
      "name": "github",
      "config": {
        "type": "http",
        "url": "https://api.githubcopilot.com/mcp/",
        "headers": {
          "X-MCP-Toolsets": "context,repos,issues,pull_requests,actions,labels,notifications",
          "X-MCP-Readonly": "true",
          "X-MCP-Lockdown": "false"
        }
      },
      "optional": false,
      "trust_note": "GitHub MCP requires OAuth authentication in VS Code. After install, open the Command Palette → MCP: List Servers → Start 'github' → Complete OAuth."
    },
    {
      "name": "sequential-thinking",
      "config": {
        "command": "npx",
        "args": ["mcp-server-sequential-thinking"]
      },
      "optional": false
    },
    {
      "name": "filesystem",
      "config": {
        "command": "npx",
        "args": ["mcp-server-filesystem", "${workspaceFolder}"]
      },
      "optional": false
    },
    {
      "name": "open-websearch",
      "config": {
        "command": "npx",
        "args": ["open-websearch"],
        "env": {
          "MODE": "stdio",
          "DEFAULT_SEARCH_ENGINE": "duckduckgo"
        }
      },
      "optional": false
    },
    {
      "name": "context7",
      "config": {
        "type": "stdio",
        "command": "bash",
        "args": ["${workspaceFolder}/.github/scripts/start-context7-mcp.sh"]
      },
      "optional": true,
      "requires_secret": "CONTEXT7_API_KEY",
      "trust_note": "Context7 requires a CONTEXT7_API_KEY. Get one at https://context7.com and add it to your .env file."
    }
  ],
  "metadata": {
    "product_name": "Research-Driven Setup",
    "repository": "https://github.com/lukasozar1994-lang/szablon_agent",
    "license": "MIT"
  }
}
